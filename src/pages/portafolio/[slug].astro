<script>
  (function () {
    const btn = document.getElementById("load-more");
    if (!btn) return;

    const grid = document.getElementById("gallery-grid");
    const items = grid?.querySelectorAll(".gallery-browser");
    if (!items || items.length === 0) return;

    const limit = window.innerWidth < 640 ? 3 : 4;
    let open = false;

    items.forEach((el, i) => {
      if (i >= limit) el.classList.add("hidden");
    });

    let scrollY = 0;

    btn.addEventListener("click", () => {
      open = !open;
      items.forEach((el, i) => {
        if (i >= limit) el.classList.toggle("hidden", !open);
      });
      btn.classList.toggle("open", open);
      btn.innerHTML = open
        ? 'Mostrar menos <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 15l6-6 6 6"/></svg>'
        : 'Cargar más capturas <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>';

      if (open) {
        scrollY = window.scrollY;
      } else {
        window.scrollTo({ top: scrollY, behavior: "smooth" });
      }
    });
  })();
</script>
