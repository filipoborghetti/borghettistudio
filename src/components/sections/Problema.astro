---

---

<section id="problema">
  <div class="grid-bg"></div>
  <div class="noise"></div>

  <div class="problema-inner">
    <h2 data-animate data-animate-delay="1">
      Dejá de alquilar espacio en la plataforma de <em>otra persona.</em>
    </h2>
    <p class="desc" data-animate data-animate-delay="1.5">
      Instagram cambia. Spotify cambia. Tu música se merece un hogar que sea
      realmente tuyo.
    </p>
    <div data-animate data-animate-delay="2">
      <a href="#casos" class="cta">
        Ver casos de éxito
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-arrow-big-down-dash-icon lucide-arrow-big-down-dash"
          ><path
            d="M14 8a1 1 0 0 1 1 1v2a1 1 0 0 0 1 1h3.293a.707.707 0 0 1 .5 1.207l-6.939 6.939a1.207 1.207 0 0 1-1.708 0l-6.94-6.94a.707.707 0 0 1 .5-1.206H8a1 1 0 0 0 1-1V9a1 1 0 0 1 1-1z"
          ></path><path d="M9 4h6"></path></svg
        >
      </a>
    </div>
  </div>
</section>

<style>
  #problema {
    position: relative;
    padding: 3rem 1.5rem;
    background: #0d0d0d;
    overflow: hidden;
    text-align: center;
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(240, 237, 230, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(240, 237, 230, 0.04) 1px, transparent 1px);
    background-size: 150px 150px;
    z-index: 0;
  }

  .noise {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    pointer-events: none;
  }

  .problema-inner {
    position: relative;
    z-index: 2;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  h2 {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--cream);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  h2 em {
    font-style: italic;
    color: var(--red);
  }

  .desc {
    font-size: 0.95rem;
    color: rgba(240, 237, 230, 0.5);
    line-height: 1.7;
    margin-bottom: 1rem;
    max-width: 400px;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--red);
    color: var(--cream);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.87rem 1.75rem;
    border-radius: 6px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    width: fit-content;
    box-shadow: 0 0 20px rgba(232, 33, 59, 0.4);
    transition:
      box-shadow 0.2s ease,
      background 0.2s ease;
  }

  .cta:hover {
    background: #ff3350;
    box-shadow: 0 0 35px rgba(232, 33, 59, 0.7);
  }

  .cta:focus-visible {
    outline: 2px solid var(--cream);
    outline-offset: 4px;
  }

  @media (min-width: 768px) {
    #problema {
      padding: 3rem 2rem;
    }

    h2 {
      font-size: 5rem;
      margin-bottom: 2rem;
    }

    .desc {
      font-size: 1.05rem;
      max-width: 480px;
      margin-bottom: 3rem;
    }

    .problema-inner {
      max-width: 1000px;
    }
  }
</style>
